---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContentCard from "../../../components/ContentCard.astro";
import { entrySlug, formatDate, isLang, languages, type Lang, ui } from "../../../i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang: Lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = ui[lang];
const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft && entry.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout lang={lang} title={t.sections.writing} description={lang === "zh" ? "研究笔记与项目更新。" : "Research notes and project updates."}>
  <section class="section">
    <p class="eyebrow">{t.sections.writing}</p>
    <h1>{t.sections.writing}</h1>
    <p class="lede">{lang === "zh" ? "研究笔记、实现日志和 MDX 文章。" : "Research notes, implementation logs, and MDX essays."}</p>
    <div class="list">
      {
        posts.map((entry) => (
          <ContentCard
            lang={lang}
            title={entry.data.title}
            description={entry.data.description}
            href={`/${lang}/blog/${entrySlug(entry)}/`}
            meta={formatDate(entry.data.date, lang)}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
