      { label: "Phone", value: "+86 18615276438", href: "tel:+8618615276438" },
      { label: "Email", value: "liyihan.xyz@gmail.com", href: "mailto:liyihan.xyz@gmail.com" },
      { label: "Website", value: "liyihan.xyz", href: "https://liyihan.xyz" },
      { label: "GitHub", value: "HY-LiYihan", href: "https://github.com/HY-LiYihan" },
      {
        label: "Google Scholar",
        value: "Profile",
        href: "https://scholar.google.com/citations?hl=en&user=Hmkl-ScAAAAJ",
      },
    ],
    sections: {
      publications: "Publications",
      internships: "Internship Experience",
      projects: "Project Experience",
      awards: "Awards",
      skills: "Skills and Other",
