        bullets: [
          "Proposed a Camera-to-Traversability pipeline that maps RGB inputs from pinhole, fisheye, and panoramic cameras to 360° radial traversability distances.",
          "Built the OmniTrav dataset with 4.7k scenes, 250k frames, and 577 GB of data, using foundation-model-assisted automatic annotation.",
          "Outperformed ResNet-FC and DINOv3-MLP baselines across camera types, reaching panoramic obstacle-detection F1 of 1.0 and median pinhole-camera error of 0.27 m.",
        ],
      },
      {
        title: "RAPID Hand Perception-integrated Dexterous Manipulation Platform",
        meta: "Research Assistant · Advisor: Prof. Hui Cheng · Nov 2024 - Jun 2025",
        bullets: [
          "Developed the low-level real-time motion-control driver for a 20-DoF anthropomorphic dexterous hand, maintaining a stable 1 kHz control loop.",
          "Integrated wrist vision, fingertip tactile sensing, and joint proprioception, reducing the perception pipeline latency to within 7 ms.",
          "Built a high-fidelity MuJoCo simulation and trained vision-tactile policies with Diffusion Policy for Sim2Real manipulation experiments.",
        ],
      },
      {
        title: "RoboMaster Vision System Development",
        meta: "Deputy Captain, Advisor, Navigation and Vision Algorithm Lead · Mar 2025 - Jul 2025",
        bullets: [
          "Led navigation and vision algorithm planning on NVIDIA Jetson and Intel NUC platforms.",
          "Designed an EKF-based auto-aiming system for high-speed targets and deployed YOLO armor classification with TensorRT and OpenVINO.",
          "Implemented robust communication between the vision host and STM32 controller for precise gimbal synchronization.",
        ],
      },
      {
        title: "Autonomous Off-road Navigation and Robotic-arm Grasping System",
        meta: "Project Lead · Mar 2025 - Jul 2025",
        bullets: [
          "Optimized FAST-LIO2 mapping and relocalization for degraded off-road environments using high-frequency odometry and ICP.",
          "Improved TEB local planning for high-speed navigation and fused stereo point clouds, YOLOv11, and PnP for 6-DoF robotic-arm grasping.",
        ],
      },
      {
        title: "UAV Swarm Flight with Mesh Networking and GNSS RTK",
        meta: "Core Member · Jul 2025 - Oct 2025",
        bullets: [
