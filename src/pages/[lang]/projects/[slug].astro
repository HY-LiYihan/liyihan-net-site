---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../../layouts/ContentLayout.astro";
import { entrySlug, isLang, languages, type Lang } from "../../../i18n";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return languages.flatMap((lang: Lang) =>
    projects
      .filter((entry) => !entry.data.draft && entry.data.lang === lang)
      .map((entry) => ({ params: { lang, slug: entrySlug(entry) }, props: { entry } })),
  );
}

const lang: Lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
>
  <Content />
  <div class="button-row">
    {entry.data.repo && <a class="button" href={entry.data.repo}>{lang === "zh" ? "代码仓库" : "Repository"}</a>}
    {entry.data.demo && <a class="button primary" href={entry.data.demo}>{lang === "zh" ? "演示" : "Demo"}</a>}
    {entry.data.paper && <a class="button" href={entry.data.paper}>{lang === "zh" ? "论文" : "Paper"}</a>}
  </div>
</ContentLayout>
