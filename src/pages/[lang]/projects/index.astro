---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContentCard from "../../../components/ContentCard.astro";
import { entrySlug, formatDate, isLang, languages, type Lang, ui } from "../../../i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang: Lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = ui[lang];
const projects = (await getCollection("projects"))
  .filter((entry) => !entry.data.draft && entry.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout lang={lang} title={t.sections.projects} description={lang === "zh" ? "机器人、具身智能、语料和软件项目。" : "Research and software projects."}>
  <section class="section">
    <p class="eyebrow">{lang === "zh" ? "研究系统" : "Research systems"}</p>
    <h1>{t.sections.projects}</h1>
    <p class="lede">{lang === "zh" ? "机器人、具身智能、语料、仿真和软件系统项目。" : "Selected work across robotics, embodied intelligence, corpora, simulation, and tooling."}</p>
    <div class="grid">
      {
        projects.map((entry) => (
          <ContentCard
            lang={lang}
            title={entry.data.title}
            description={entry.data.description}
            href={`/${lang}/projects/${entrySlug(entry)}/`}
            meta={formatDate(entry.data.date, lang)}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
