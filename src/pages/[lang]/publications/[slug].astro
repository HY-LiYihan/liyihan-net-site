---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../../layouts/ContentLayout.astro";
import { entrySlug, isLang, languages, type Lang } from "../../../i18n";

export async function getStaticPaths() {
  const publications = await getCollection("publications");
  return languages.flatMap((lang: Lang) =>
    publications
      .filter((entry) => entry.data.lang === lang)
      .map((entry) => ({ params: { lang, slug: entrySlug(entry) }, props: { entry } })),
  );
}

const lang: Lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
>
  <p class="meta">
    {entry.data.authors.join(", ")} · {entry.data.venue}, {entry.data.year}
  </p>
  <Content />
  <div class="button-row">
    {entry.data.paper && <a class="button primary" href={entry.data.paper}>{lang === "zh" ? "论文" : "Paper"}</a>}
    {entry.data.code && <a class="button" href={entry.data.code}>{lang === "zh" ? "代码" : "Code"}</a>}
    {entry.data.project && <a class="button" href={entry.data.project}>{lang === "zh" ? "项目" : "Project"}</a>}
  </div>
</ContentLayout>
