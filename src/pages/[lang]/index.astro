---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";
import LinkButton from "../../components/LinkButton.astro";
import { entrySlug, formatDate, isLang, languages, ui } from "../../i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = ui[lang];
const projects = (await getCollection("projects"))
  .filter((entry) => !entry.data.draft && entry.data.featured && entry.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const publications = (await getCollection("publications"))
  .filter((entry) => entry.data.featured && entry.data.lang === lang)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<BaseLayout lang={lang}>
  <section class="section hero">
    <div>
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1>{t.hero.title}</h1>
      <p class="lede">{t.hero.lede}</p>
      <div class="button-row">
        <LinkButton href={`/${lang}/cv/`} label={t.hero.primary} primary />
        <LinkButton href={`/${lang}/projects/`} label={t.hero.secondary} />
      </div>
    </div>
    <aside class="hero-visual" aria-label="Research profile visual">
      <img class="hero-avatar" src="/images/old-site/profile.png" alt="Yihan Li profile image" />
      <img src="/images/research-workspace.svg" alt="Abstract research workspace with corpus nodes, charts, and interface panels" />
    </aside>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="panel">
      <h2>{t.hero.focusTitle}</h2>
      <p>{t.hero.focusBody}</p>
      <div class="tag-row">
        {t.skills.map((skill) => <span class="tag">{skill}</span>)}
      </div>
    </div>
  </section>

  <section class="section">
    <h2>{t.sections.featuredPublications}</h2>
    <div class="list">
      {
        publications.map((entry) => (
          <ContentCard
            lang={lang}
            title={entry.data.title}
            description={entry.data.description}
            href={`/${lang}/publications/${entrySlug(entry)}/`}
            meta={`${entry.data.venue}, ${entry.data.year}`}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>

  <section class="section">
    <h2>{t.sections.featuredProjects}</h2>
    <div class="grid">
      {
        projects.map((entry) => (
          <ContentCard
            lang={lang}
            title={entry.data.title}
            description={entry.data.description}
            href={`/${lang}/projects/${entrySlug(entry)}/`}
            meta={formatDate(entry.data.date, lang)}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
