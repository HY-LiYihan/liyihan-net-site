---
import "../styles/global.css";
import { defaultLang, switchLangPath, type Lang, ui } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  lang = defaultLang,
  title,
  description,
} = Astro.props;

const t = ui[lang];
const pageTitle = title ? `${title} | ${t.siteTitle}` : t.siteTitle;
const pageDescription = description ?? t.description;
const otherLang = lang === "en" ? "zh" : "en";
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="alternate" hreflang="en" href={switchLangPath(currentPath, "en")} />
    <link rel="alternate" hreflang="zh-CN" href={switchLangPath(currentPath, "zh")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="Primary navigation">
          <a class="brand" href={`/${lang}/`}>
            <span>{t.brand}</span>
            <small>{t.subtitle}</small>
          </a>
          <div class="nav-links">
            <a href={`/${lang}/cv/`}>{t.nav.cv}</a>
            <a href={`/${lang}/publications/`}>{t.nav.publications}</a>
            <a href={`/${lang}/projects/`}>{t.nav.projects}</a>
            <a href={`/${lang}/blog/`}>{t.nav.blog}</a>
            <a href={`/${lang}/search/`}>{t.nav.search}</a>
            <a href={switchLangPath(currentPath, otherLang)}>{otherLang === "zh" ? "中文" : "English"}</a>
          </div>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} {t.fullName} / {t.nativeName}</span>
          <span>{t.footer}</span>
        </div>
      </footer>
    </div>
  </body>
</html>
