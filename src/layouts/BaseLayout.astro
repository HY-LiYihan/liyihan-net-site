---
import "../styles/global.css";
import { defaultLang, switchLangPath, type Lang, ui } from "../i18n";
import { getSiteImages, getSiteLocale, getThemeStyle } from "../site-config";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  lang = defaultLang,
  title,
  description,
} = Astro.props;

const t = ui[lang];
const site = getSiteLocale(lang);
const images = getSiteImages();
const themeStyle = getThemeStyle() || undefined;
const pageTitle = title ? `${title} | ${site.siteTitle}` : site.siteTitle;
const pageDescription = description ?? site.description;
const otherLang = lang === "en" ? "zh" : "en";
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={t.htmlLang} style={themeStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="alternate" hreflang="en" href={switchLangPath(currentPath, "en")} />
    <link rel="alternate" hreflang="zh-CN" href={switchLangPath(currentPath, "zh")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="Primary navigation">
          <a class="brand" href={`/${lang}/`}>
            {images.logo && <img class="brand-logo" src={images.logo} alt="" />}
            <span>
              <strong>{site.brand}</strong>
              <small>{site.subtitle}</small>
            </span>
          </a>
          <div class="nav-links">
            <a href={`/${lang}/cv/`}>{t.nav.cv}</a>
            <a href={`/${lang}/publications/`}>{t.nav.publications}</a>
            <a href={`/${lang}/projects/`}>{t.nav.projects}</a>
            <a href={`/${lang}/blog/`}>{t.nav.blog}</a>
            <a href={`/${lang}/search/`}>{t.nav.search}</a>
            <a
              class="language-switch"
              href={switchLangPath(currentPath, otherLang)}
              aria-label={lang === "en" ? "Switch to Chinese" : "切换到英文"}
            >
              <span class:list={{ active: lang === "en" }}>EN</span>
              <span class:list={{ active: lang === "zh" }}>中文</span>
            </a>
          </div>
        </nav>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} {site.fullName} / {site.nativeName}</span>
          <span>{site.footer}</span>
        </div>
      </footer>
    </div>
  </body>
</html>
